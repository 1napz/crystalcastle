# Node environment
NODE_ENV=development

# Mock mode (true = ใช้วิดีโอตัวอย่าง, false = เรียก API จริง)
NEXT_PUBLIC_USE_MOCK=true

# API Keys (สำหรับ production)
FAL_KEY=fal_your_key_here
GROQ_KEY=gsk_your_key_here
MAGIC_HOUR_KEY=mh_your_key_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/crystal_castle

# Webhook (สำหรับ local development ใช้ ngrok)
WEBHOOK_BASE_URL=http://localhost:3000

# Email (Magic Link)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password